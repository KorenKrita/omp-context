{
  "name": "omp-context",
  "version": "0.1.0",
  "description": "Agentic Context Management for OMP — checkpoint, timeline, and travel tools",
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "skills",
    "README.md",
    "AGENTS.md",
    ".omp-plugin"
  ],
  "scripts": {
    "generate:guidance": "bun scripts/generate-guidance.mjs",
    "sync:acm": "bun scripts/sync-acm.mjs",
    "test:host": "bun run --cwd test/host-fixture verify",
    "verify:acm": "bun scripts/verify-acm.mjs && bun test scripts/generate-guidance.test.mjs src/version-contract.test.ts && bun run test:host",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@oh-my-pi/pi-agent-core": "16.4.2",
    "@oh-my-pi/pi-ai": "16.4.2",
    "@oh-my-pi/pi-coding-agent": "16.4.2",
    "bun-types": "^1.3.14",
    "typescript": "^5.7.2",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-agent-core": "16.4.2",
    "@oh-my-pi/pi-ai": "16.4.2",
    "@oh-my-pi/pi-coding-agent": "16.4.2"
  },
  "omp": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
